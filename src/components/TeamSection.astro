---
const team = [
  {
    name: "Noëlle Rohrbach",
    role: "Inhaberin",
    image: "/portrait-noelle.jpeg",
    description: "Dipl. Podologin HF\nBerufsbildnerin, Absolventin Diabetes- und Hygieneseminar, Mitglied des SPV",
  },
  {
    name: "Marlène Rohrbach",
    role: "Administration",
    image: "/portrait-marlene.jpeg",
    description: "",
  },
];
---

<section id="ueber-uns" class="w-full py-[12vh] px-[5vw] bg-primary">
  <div class="fade-up">
    <h2 class="text-[clamp(2rem,7vw,8rem)] leading-[0.95] text-primary-foreground mb-[2vh]">
      Über uns
    </h2>
    <p class="font-body text-[clamp(1rem,1.8vw,1.4rem)] font-light text-primary-foreground/80 mb-[8vh] max-w-[600px]">
      Lernen Sie unser Team kennen. Unser erfahrenes Team arbeitet mit Kompetenz und Herz. Gemeinsam sorgen wir dafür, dass Sie sich jederzeit gut aufgehoben fühlen.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-[4vw]">
    {team.map((member) => (
      <div class="group fade-up">
        <div class="overflow-hidden mb-6">
          <img
            src={member.image}
            alt={member.name}
            class="w-full aspect-[3/4] object-cover object-top transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <h3 class="text-[clamp(1.2rem,3vw,2.5rem)] text-primary-foreground">
          {member.name}
        </h3>
        <p class="font-body text-[clamp(0.9rem,1.4vw,1.2rem)] font-medium text-primary-foreground/60 mb-2">
          {member.role}
        </p>
        {member.description && (
          <p class="font-body text-[clamp(0.85rem,1.2vw,1.1rem)] font-light text-primary-foreground/70 leading-relaxed whitespace-pre-line">
            {member.description}
          </p>
        )}
      </div>
    ))}
  </div>
</section>
