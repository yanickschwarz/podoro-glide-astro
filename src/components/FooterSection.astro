---
---
<footer class="w-full py-[6vh] px-[5vw] bg-primary border-t border-primary-foreground/10">
  <div class="flex flex-col md:flex-row items-start justify-between gap-10">
    <!-- Logo + Slogan -->
    <div>
      <a href="/"><img src="/logo-podoro.png" alt="PODORO" class="w-[120px] opacity-60 mb-4" width="120" height="40" /></a>
      <p class="font-body text-[clamp(0.8rem,1.1vw,1rem)] font-light text-primary-foreground/50 max-w-[240px] leading-relaxed">
        Medizinische Fusspflege mit Herz und Kompetenz – in Muri AG.
      </p>
    </div>

    <!-- Navigation -->
    <div>
      <h3 class="font-body text-xs tracking-[0.2em] uppercase text-primary-foreground/40 mb-4">Navigation</h3>
      <nav class="flex flex-col gap-2" aria-label="Footer Navigation">
        <a href="/leistungen" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Leistungen</a>
        <a href="/ueber-uns" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Über uns</a>
        <a href="/galerie" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Galerie</a>
        <a href="/kontakt" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Kontakt</a>
      </nav>
    </div>

    <!-- Kontakt -->
    <div>
      <h3 class="font-body text-xs tracking-[0.2em] uppercase text-primary-foreground/40 mb-4">Kontakt</h3>
      <address class="not-italic font-body text-sm text-primary-foreground/70 flex flex-col gap-1.5 leading-relaxed">
        <span>Luzernerstrasse 15b<br/>5630 Muri AG</span>
        <a href="tel:+41566107070" class="hover:text-primary-foreground transition-colors">+41 56 610 70 70</a>
        <a href="mailto:info@podoro.ch" class="hover:text-primary-foreground transition-colors">info@podoro.ch</a>
      </address>
    </div>

    <!-- Rechtliches -->
    <div>
      <h3 class="font-body text-xs tracking-[0.2em] uppercase text-primary-foreground/40 mb-4">Rechtliches</h3>
      <nav class="flex flex-col gap-2">
        <a href="/impressum" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Impressum</a>
        <a href="/datenschutz" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">Datenschutz</a>
        <a href="/agb" class="font-body text-sm text-primary-foreground/70 hover:text-primary-foreground/100 transition-colors">AGB</a>
      </nav>
    </div>
  </div>

  <div class="mt-10 pt-6 border-t border-primary-foreground/10 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="font-body text-[clamp(0.7rem,0.9vw,0.85rem)] font-light text-primary-foreground/30">
      © {new Date().getFullYear()} PODORO GmbH. Alle Rechte vorbehalten.
    </p>
    <p class="font-body text-[clamp(0.7rem,0.9vw,0.85rem)] font-light text-primary-foreground/30">
      Podologiepraxis in Muri AG – Schweiz
    </p>
  </div>
</footer>
