---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import FooterSection from '../components/FooterSection.astro';
import '../styles/global.css';

const images = [
  { src: "/fusspflege.jpeg", alt: "Medizinische Fusspflege – Behandlung in der Praxis PODORO Muri AG", caption: "Medizinische Behandlung" },
  { src: "/fuesse.jpeg", alt: "Gepflegte Füsse nach Podologie-Behandlung bei PODORO", caption: "Gepflegte Füsse" },
  { src: "/portrait-noelle.jpeg", alt: "Noëlle Rohrbach – dipl. Podologin HF, Inhaberin PODORO", caption: "Noëlle Rohrbach, Inhaberin" },
  { src: "/portrait-marlene.jpeg", alt: "Marlène Rohrbach – Administration bei PODORO Muri", caption: "Marlène Rohrbach, Administration" },
];
---

<Layout
  title="Galerie – Einblick in die PODORO Podologiepraxis Muri AG"
  description="Bilder aus der Podologiepraxis PODORO in Muri AG. Einblick in unsere Behandlungen, Räumlichkeiten und unser Team."
  canonical="/galerie"
>
  <Navigation />

  <main class="pt-[18vh]">
    <section class="px-[5vw] pb-[14vh]">
      <h1 class="text-[clamp(3rem,10vw,11rem)] leading-[0.95] text-primary mb-[4vh] fade-up">
        Galerie
      </h1>
      <p class="font-body text-[clamp(1rem,1.8vw,1.4rem)] font-light text-muted-foreground max-w-[540px] fade-up leading-relaxed mb-[8vh]">
        Einblicke in unsere Praxis, unsere Behandlungen und unser Team.
      </p>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[3vw]">
        {images.map((img) => (
          <figure class="fade-up group overflow-hidden">
            <div class="overflow-hidden">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full aspect-[4/3] object-cover object-center transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <figcaption class="font-body text-sm text-muted-foreground mt-3 tracking-wide">
              {img.caption}
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="px-[5vw] py-[10vh] bg-primary text-center">
      <h2 class="text-[clamp(1.8rem,5vw,5rem)] leading-[0.95] text-primary-foreground mb-6 fade-up">
        Überzeugen Sie sich selbst
      </h2>
      <p class="font-body text-[clamp(1rem,1.5vw,1.2rem)] font-light text-primary-foreground/70 mb-8 fade-up">
        Vereinbaren Sie noch heute Ihren Termin und erleben Sie die PODORO-Qualität.
      </p>
      <a href="/kontakt" class="fade-up inline-block font-body text-sm tracking-[0.2em] uppercase text-primary-foreground border border-primary-foreground/40 px-10 py-4 hover:bg-primary-foreground hover:text-primary transition-all duration-300">
        Termin anfragen
      </a>
    </section>
  </main>

  <FooterSection />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); } }); },
    { threshold: 0.1, rootMargin: '-80px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => { observer.observe(el); });
  const mainNav = document.getElementById('main-nav');
  setTimeout(() => { mainNav?.classList.add('visible'); }, 100);
</script>
